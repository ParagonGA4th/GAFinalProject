            <mxRectangle x="230" y="140" width="160" height="26" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-19" value=" = 프레임버퍼 / Layer의 나열 순서,&#xa;특징 등을 저장해놓는다.&#xa;&#xa;- 순서대로 발동시키며, &#xa;Opaque Deferred -&gt; etc. -&gt; &#xa;PostProcessing -&gt; UI 순서를 유지." style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="lLuolTyeRvQu0_JksktK-18">
          <mxGeometry y="26" width="210" height="114" as="geometry" />
        </mxCell>
