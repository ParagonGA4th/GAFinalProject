        <mxCell id="lLuolTyeRvQu0_JksktK-13" value=" = .hlsl과 대응, &#xa;해석한 바이너리 &#xa;정보를 들고 있다. " style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="lLuolTyeRvQu0_JksktK-12">
          <mxGeometry y="26" width="180" height="54" as="geometry" />
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-14" value="ShaderMaterial" style="swimlane;fontStyle=2;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=0;shadow=0;strokeWidth=1;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="830" y="980" width="210" height="140" as="geometry">
            <mxRectangle x="230" y="140" width="160" height="26" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-15" value=" = Shader를 가지고 있고, &#xa;각각에 대응될 Property 갖고 있음.&#xa; - HLSL Parser를 통해 HLSL의 &#xa;프로퍼티 / GPU 변수들을 가져오고&#xa;(ShaderReflection) -&gt; 연동한다.&#xa; &#xa;Mk1 : 단순 If/Else로 구분할수도" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="lLuolTyeRvQu0_JksktK-14">
          <mxGeometry y="26" width="210" height="114" as="geometry" />
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-16" value="CameraInformation" style="swimlane;fontStyle=2;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=0;shadow=0;strokeWidth=1;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="310" y="470" width="210" height="140" as="geometry">
            <mxRectangle x="230" y="140" width="160" height="26" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-17" value="= 렌더링에 고유함,&#xa; Camera Component 중에 &#xa;우선도가 가장 0에 가까운 옵젝의 &#xa;View / Projection 정보를 가져온다.&#xa;&#xa;- 메인 카메라의 행렬 정보, &#xa;매 순간 업뎃" style="text;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="lLuolTyeRvQu0_JksktK-16">
          <mxGeometry y="26" width="210" height="114" as="geometry" />
        </mxCell>
        <mxCell id="lLuolTyeRvQu0_JksktK-18" value="RenderQueue" style="swimlane;fontStyle=2;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeLast=0;collapsible=1;marginBottom=0;rounded=0;shadow=0;strokeWidth=1;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
